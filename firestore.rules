rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Role comes from Firebase custom claims (set server-side in Phase 2)
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- users/{userId} ---

    match /users/{userId} {
      // Users can read their own profile; admins can read any profile
      allow read: if isOwner(userId) || isAdmin();

      // All writes go through our API (Firebase Admin SDK bypasses these rules)
      allow create, update, delete: if false;
    }

    // --- products/{productId} ---

    match /products/{productId} {
      // Any signed-in user can read products (viewer + admin)
      allow read: if isSignedIn();

      // Mutations only via API routes — prevents direct client tampering
      allow create, update, delete: if false;
    }
  }
}
